{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "스토리 아이템 스키마",
  "type": "object",
  "required": ["id", "stage", "created_at"],
  "properties": {
    "id": { "type": "string" },
    "stage": { "type": "string", "enum": ["sourced","assigned","reported","drafted","fact-checked","desk-approved","copy-edited","published","rejected","killed"] },
    "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "revision_count": { "type": "integer", "default": 0 },

    "source": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "source_name": { "type": "string" },
        "relevance_score": { "type": "integer", "minimum": 0, "maximum": 100 },
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string", "enum": ["policy","research","industry","opinion","data"] } }
      }
    },

    "reporting_brief": {
      "type": "object",
      "properties": {
        "facts": { "type": "array", "items": { "type": "object", "properties": { "claim": {"type":"string"}, "source_url": {"type":"string"}, "quote": {"type":"string"} } } },
        "perspectives": { "type": "array", "items": { "type": "string" } },
        "suggested_angle": { "type": "string" },
        "sources_used": { "type": "array", "items": { "type": "string" } },
        "gaps": { "type": "array", "items": { "type": "string" } }
      }
    },

    "draft": {
      "type": "object",
      "properties": {
        "headline": { "type": "string", "maxLength": 30 },
        "subheadline": { "type": "string" },
        "html": { "type": "string" },
        "ghost_tags": { "type": "array", "items": { "type": "string" } },
        "references": { "type": "array", "items": { "type": "object" } },
        "word_count": { "type": "integer" },
        "article_type": { "type": "string", "enum": ["blog","news","deep-dive"] }
      }
    },

    "fact_check_report": {
      "type": "object",
      "properties": {
        "overall_confidence": { "type": "integer" },
        "verdict": { "type": "string", "enum": ["PASS","FLAG","FAIL"] },
        "claims": { "type": "array" }
      }
    },

    "desk_decision": {
      "type": "object",
      "properties": {
        "decision": { "type": "string", "enum": ["APPROVE","REVISE","REWRITE","KILL"] },
        "reason": { "type": "string" },
        "instructions": { "type": "string" },
        "checklist": { "type": "object" }
      }
    },

    "copy_edit": {
      "type": "object",
      "properties": {
        "final_html": { "type": "string" },
        "changes": { "type": "array" },
        "readability_score": { "type": "integer" },
        "links_checked": { "type": "boolean" }
      }
    },

    "publish_result": {
      "type": "object",
      "properties": {
        "ghost_post_id": { "type": "string" },
        "ghost_draft_url": { "type": "string" },
        "status": { "type": "string", "enum": ["draft","scheduled"] },
        "scheduled_at": { "type": "string" }
      }
    },

    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "timestamp": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
